<Window x:Class="CircuitForge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Circuit Forge" Height="820" Width="1260" MinHeight="720" MinWidth="1040"
        Background="#111318" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#171A21"/>
        <SolidColorBrush x:Key="PanelAltBrush" Color="#1F2430"/>
        <SolidColorBrush x:Key="LineBrush" Color="#2D3441"/>
        <SolidColorBrush x:Key="TextBrush" Color="#EEF2F8"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#9AA7B8"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#42C6A7"/>
        <Style TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ToolButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="92"/>
            <Setter Property="Background" Value="#202631"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ToolButton}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="#06110E"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style x:Key="SidebarButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="56"/>
            <ColumnDefinition Width="310"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#0B0D11" BorderBrush="#222833" BorderThickness="0,0,1,0">
            <StackPanel Margin="8,14">
                <Button Height="38" Content="WS" Background="#20382F" Foreground="{StaticResource AccentBrush}" FontWeight="Bold"/>
                <Button Height="38" Content="BD" Margin="0,10,0,0"/>
                <Button Height="38" Content="?" Margin="0,10,0,0"/>
                <Button Height="38" Content="IO" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,1,0">
            <StackPanel Margin="18">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                    <Border Width="44" Height="44" CornerRadius="8" Background="{StaticResource AccentBrush}">
                        <TextBlock Text="CF" Foreground="#06110E" FontWeight="Black" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Circuit Forge" FontSize="17" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Text="Embedded learning IDE" Foreground="{StaticResource MutedBrush}" FontSize="12"/>
                    </StackPanel>
                </StackPanel>

                <Border BorderBrush="{StaticResource LineBrush}" BorderThickness="0,1,0,0" Padding="0,14,0,0">
                    <StackPanel>
                        <DockPanel Height="34">
                            <TextBlock Text="PROJECT" Foreground="{StaticResource MutedBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                            <Button Content="+" Width="32" Height="32" DockPanel.Dock="Right"/>
                        </DockPanel>
                        <Button Style="{StaticResource SidebarButton}" Content="  src/main.cpp" Background="{StaticResource PanelAltBrush}" Foreground="{StaticResource TextBrush}" Click="OpenMainFile"/>
                        <Button Style="{StaticResource SidebarButton}" Content="  platformio.ini" Click="OpenConfigFile"/>
                        <Button Style="{StaticResource SidebarButton}" Content="  learning-notes.md" Click="OpenNotesFile"/>
                    </StackPanel>
                </Border>

                <Border BorderBrush="{StaticResource LineBrush}" BorderThickness="0,1,0,0" Padding="0,14,0,0" Margin="0,18,0,0">
                    <StackPanel>
                        <DockPanel Height="34">
                            <TextBlock Text="DEVICE" Foreground="{StaticResource MutedBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                            <Border DockPanel.Dock="Right" Background="#20382F" CornerRadius="10" Padding="8,3">
                                <TextBlock x:Name="PlatformIoStatusText" Text="PIO" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="Bold"/>
                            </Border>
                        </DockPanel>
                        <TextBlock Text="Type" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,8,0,6"/>
                        <ComboBox x:Name="DeviceTypeSelector" Height="38" SelectionChanged="DeviceTypeSelectorChanged"/>
                        <TextBlock Text="Board" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,10,0,6"/>
                        <ComboBox x:Name="BoardSelector" Height="38" SelectionChanged="BoardSelectorChanged"/>
                        <UniformGrid Columns="2" Margin="0,10,0,0">
                            <Border Background="#141821" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,4,0">
                                <StackPanel>
                                    <TextBlock Text="Clock" Foreground="{StaticResource MutedBrush}" FontSize="12"/>
                                    <TextBlock x:Name="ClockText" Text="16 MHz" Foreground="{StaticResource TextBrush}" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#141821" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="6" Padding="10" Margin="4,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="Flash" Foreground="{StaticResource MutedBrush}" FontSize="12"/>
                                    <TextBlock x:Name="FlashText" Text="32 KB" Foreground="{StaticResource TextBrush}" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Border BorderBrush="{StaticResource LineBrush}" BorderThickness="0,1,0,0" Padding="0,14,0,0" Margin="0,18,0,0">
                    <StackPanel>
                        <DockPanel Height="34">
                            <TextBlock Text="DEVICE TYPES" Foreground="{StaticResource MutedBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock x:Name="DeviceCountText" Text="0" DockPanel.Dock="Right" Foreground="{StaticResource MutedBrush}" FontSize="12" VerticalAlignment="Center"/>
                        </DockPanel>
                        <TextBlock Text="ESP32 / ESP8266" Foreground="{StaticResource AccentBrush}" Margin="0,6,0,0"/>
                        <TextBlock Text="Arduino AVR / SAMD" Foreground="{StaticResource TextBrush}" FontWeight="Bold" Margin="0,8,0,0"/>
                        <TextBlock Text="RP2040 / Pico" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,0"/>
                        <TextBlock Text="STM32 / Teensy / nRF52" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="62"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="190"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#111318" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1">
                <DockPanel Margin="20,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Starter Kit" Foreground="{StaticResource MutedBrush}" FontSize="12"/>
                        <TextBlock x:Name="ActiveFileText" Text="src/main.cpp" Foreground="{StaticResource TextBrush}" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Style="{StaticResource ToolButton}" Content="Verify" Margin="0,0,8,0" Click="VerifyClicked"/>
                        <Button Style="{StaticResource PrimaryButton}" Content="Upload" Margin="0,0,8,0" Click="UploadClicked"/>
                        <Button Style="{StaticResource ToolButton}" Content="Serial" Margin="0,0,8,0" Click="SerialClicked"/>
                        <Button Style="{StaticResource ToolButton}" Content="Settings"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="330"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="44"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Background="#111318" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="12,0,0,0">
                            <Border Background="#151922" BorderBrush="{StaticResource LineBrush}" BorderThickness="1,1,1,0" CornerRadius="7,7,0,0" Padding="16,9">
                                <TextBlock Text="main.cpp" Foreground="{StaticResource TextBrush}"/>
                            </Border>
                            <Border Padding="16,9">
                                <TextBlock Text="platformio.ini" Foreground="{StaticResource MutedBrush}"/>
                            </Border>
                        </StackPanel>
                    </Border>
                    <Grid Grid.Row="1" Background="#151922">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="54"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="LineNumbersText" Background="#11151D" Foreground="#657184" FontFamily="Consolas" FontSize="14" LineHeight="23" TextAlignment="Right" Padding="0,18,12,0"/>
                        <TextBox x:Name="EditorText" Grid.Column="1" Background="#151922" Foreground="{StaticResource TextBrush}" BorderThickness="0" FontFamily="Consolas" FontSize="14" Padding="20,16" AcceptsReturn="True" AcceptsTab="True" TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                    </Grid>
                </Grid>

                <Border Grid.Column="1" Background="#131720" BorderBrush="{StaticResource LineBrush}" BorderThickness="1,0,0,0" Padding="16">
                    <StackPanel>
                        <Border Background="#181D27" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8" Padding="14">
                            <StackPanel>
                                <DockPanel>
                                    <TextBlock Text="Selected Device" Foreground="{StaticResource MutedBrush}" FontSize="12"/>
                                    <TextBlock x:Name="DeviceFamilyText" Text="Arduino AVR" DockPanel.Dock="Right" Foreground="{StaticResource TextBrush}" FontWeight="Bold"/>
                                </DockPanel>
                                <TextBlock x:Name="DeviceDescriptionText" Text="Arduino Uno R3 using the atmelavr platform." TextWrapping="Wrap" Foreground="#C5CEDA" LineHeight="21" Margin="0,12,0,14"/>
                                <DockPanel Margin="0,8"><TextBlock Text="Platform" Foreground="{StaticResource MutedBrush}"/><TextBlock x:Name="PlatformText" Text="atmelavr" DockPanel.Dock="Right" Foreground="{StaticResource TextBrush}" FontWeight="Bold"/></DockPanel>
                                <DockPanel Margin="0,8"><TextBlock Text="Board ID" Foreground="{StaticResource MutedBrush}"/><TextBlock x:Name="BoardIdText" Text="uno" DockPanel.Dock="Right" Foreground="{StaticResource TextBrush}" FontWeight="Bold"/></DockPanel>
                                <DockPanel Margin="0,8"><TextBlock Text="Framework" Foreground="{StaticResource MutedBrush}"/><TextBlock x:Name="BoardFrameworkText" Text="arduino" DockPanel.Dock="Right" Foreground="{StaticResource TextBrush}" FontWeight="Bold"/></DockPanel>
                            </StackPanel>
                        </Border>

                        <Border Background="#181D27" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,14,0,0">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="Board Health" Foreground="{StaticResource MutedBrush}" FontSize="12"/>
                                    <TextBlock Text="Ready" DockPanel.Dock="Right" Foreground="{StaticResource AccentBrush}" FontWeight="Bold"/>
                                </DockPanel>
                                <DockPanel Margin="0,8"><TextBlock Text="Project" Foreground="{StaticResource MutedBrush}"/><TextBlock x:Name="ProjectPathText" Text="StarterKit" DockPanel.Dock="Right" Foreground="{StaticResource TextBrush}" FontWeight="Bold"/></DockPanel>
                                <DockPanel Margin="0,8"><TextBlock Text="Port" Foreground="{StaticResource MutedBrush}"/><TextBlock Text="Auto" DockPanel.Dock="Right" Foreground="{StaticResource TextBrush}" FontWeight="Bold"/></DockPanel>
                                <DockPanel Margin="0,8"><TextBlock Text="Baud" Foreground="{StaticResource MutedBrush}"/><TextBlock Text="115200" DockPanel.Dock="Right" Foreground="{StaticResource TextBrush}" FontWeight="Bold"/></DockPanel>
                                <DockPanel Margin="0,8"><TextBlock Text="Framework" Foreground="{StaticResource MutedBrush}"/><TextBlock Text="Arduino" DockPanel.Dock="Right" Foreground="{StaticResource TextBrush}" FontWeight="Bold"/></DockPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2" Background="#101319" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="42"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="14,6,0,0">
                        <Button Content="Problems" Background="{StaticResource PanelAltBrush}" BorderBrush="{StaticResource LineBrush}" Height="30" Padding="12,0"/>
                        <Button Content="Output" Foreground="{StaticResource MutedBrush}" Height="30" Padding="12,0"/>
                        <Button Content="Serial Monitor" Foreground="{StaticResource MutedBrush}" Height="30" Padding="12,0"/>
                    </StackPanel>
                    <TextBox x:Name="ConsoleText" Grid.Row="1" Background="#101319" Foreground="{StaticResource MutedBrush}" BorderThickness="0" FontFamily="Consolas" FontSize="13" Padding="18,12" IsReadOnly="True" Text="Ready. PlatformIO commands will run against the StarterKit project." VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>

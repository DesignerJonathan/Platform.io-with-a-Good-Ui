<Window x:Class="CircuitForge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Circuit Forge" Height="820" Width="1280" MinHeight="740" MinWidth="1100"
        Background="#101216" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="ShellBrush" Color="#101216"/>
        <SolidColorBrush x:Key="RailBrush" Color="#0B0D11"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#171A21"/>
        <SolidColorBrush x:Key="PanelAltBrush" Color="#202632"/>
        <SolidColorBrush x:Key="EditorBrush" Color="#141922"/>
        <SolidColorBrush x:Key="ConsoleBrush" Color="#0F1319"/>
        <SolidColorBrush x:Key="LineBrush" Color="#2D3441"/>
        <SolidColorBrush x:Key="SoftLineBrush" Color="#252B36"/>
        <SolidColorBrush x:Key="TextBrush" Color="#EEF2F8"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#9AA7B8"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#42C6A7"/>
        <SolidColorBrush x:Key="BlueBrush" Color="#70A8FF"/>
        <SolidColorBrush x:Key="AmberBrush" Color="#F3B64B"/>

        <Style TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RailButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Background" Value="#11161D"/>
            <Setter Property="BorderBrush" Value="#1D2430"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="ToolButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="88"/>
            <Setter Property="Background" Value="#202631"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ToolButton}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="#06110E"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="SidebarButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="36"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="12,0"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="#181D27"/>
            <Setter Property="BorderBrush" Value="{StaticResource SoftLineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14"/>
        </Style>

        <Style x:Key="DockButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="64"/>
            <ColumnDefinition Width="330"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource RailBrush}" BorderBrush="#222833" BorderThickness="0,0,1,0">
            <DockPanel Margin="10,14">
                <StackPanel DockPanel.Dock="Top">
                    <Button Style="{StaticResource RailButton}" Content="WS" ToolTip="Workspace" Background="#20382F" Foreground="{StaticResource AccentBrush}" Click="WorkspaceClicked"/>
                    <Button Style="{StaticResource RailButton}" Content="BD" ToolTip="Boards" Click="BoardsClicked"/>
                    <Button Style="{StaticResource RailButton}" Content="IO" ToolTip="Serial Monitor" Click="SerialClicked"/>
                    <Button Style="{StaticResource RailButton}" Content="?" ToolTip="Help" Click="HelpClicked"/>
                </StackPanel>
                <TextBlock DockPanel.Dock="Bottom" Text="PIO" Foreground="{StaticResource MutedBrush}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
            </DockPanel>
        </Border>

        <Border Grid.Column="1" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="18">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                        <Border Width="44" Height="44" CornerRadius="8" Background="{StaticResource AccentBrush}">
                            <TextBlock Text="CF" Foreground="#06110E" FontWeight="Black" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Circuit Forge" FontSize="17" FontWeight="Bold" Foreground="{StaticResource TextBrush}" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="PlatformIO desktop IDE" Foreground="{StaticResource MutedBrush}" FontSize="12" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </StackPanel>

                    <Border BorderBrush="{StaticResource LineBrush}" BorderThickness="0,1,0,0" Padding="0,14,0,0">
                        <StackPanel>
                            <DockPanel Height="34">
                                <TextBlock Style="{StaticResource SectionTitle}" Text="PROJECT" VerticalAlignment="Center"/>
                                <Button Content="+" Width="32" Height="32" DockPanel.Dock="Right" ToolTip="Reset starter sketch" Click="NewSketchClicked"/>
                            </DockPanel>
                            <Button Style="{StaticResource SidebarButton}" Content="src/main.cpp" Background="{StaticResource PanelAltBrush}" Foreground="{StaticResource TextBrush}" Click="OpenMainFile"/>
                            <Button Style="{StaticResource SidebarButton}" Content="platformio.ini" Click="OpenConfigFile"/>
                            <Button Style="{StaticResource SidebarButton}" Content="project-notes.md" Click="OpenNotesFile"/>
                        </StackPanel>
                    </Border>

                    <Border BorderBrush="{StaticResource LineBrush}" BorderThickness="0,1,0,0" Padding="0,14,0,0" Margin="0,18,0,0">
                        <StackPanel>
                            <DockPanel Height="34">
                                <TextBlock Style="{StaticResource SectionTitle}" Text="TARGET DEVICE" VerticalAlignment="Center"/>
                                <Border DockPanel.Dock="Right" Background="#20382F" CornerRadius="10" Padding="8,3">
                                    <TextBlock x:Name="PlatformIoStatusText" Text="PIO" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="Bold"/>
                                </Border>
                            </DockPanel>
                            <TextBlock Text="Type" Style="{StaticResource MutedText}" Margin="0,8,0,6"/>
                            <ComboBox x:Name="DeviceTypeSelector" Height="38" SelectionChanged="DeviceTypeSelectorChanged"/>
                            <TextBlock Text="Board" Style="{StaticResource MutedText}" Margin="0,10,0,6"/>
                            <ComboBox x:Name="BoardSelector" Height="38" DisplayMemberPath="Name" SelectionChanged="BoardSelectorChanged"/>
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#141821" BorderBrush="{StaticResource SoftLineBrush}" BorderThickness="1" CornerRadius="7" Padding="10">
                                    <StackPanel>
                                        <TextBlock Text="Clock" Style="{StaticResource MutedText}"/>
                                        <TextBlock x:Name="ClockText" Text="16 MHz" Foreground="{StaticResource TextBrush}" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Background="#141821" BorderBrush="{StaticResource SoftLineBrush}" BorderThickness="1" CornerRadius="7" Padding="10">
                                    <StackPanel>
                                        <TextBlock Text="Flash" Style="{StaticResource MutedText}"/>
                                        <TextBlock x:Name="FlashText" Text="32 KB" Foreground="{StaticResource TextBrush}" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border BorderBrush="{StaticResource LineBrush}" BorderThickness="0,1,0,0" Padding="0,14,0,0" Margin="0,18,0,0">
                        <StackPanel>
                            <DockPanel Height="34">
                                <TextBlock Style="{StaticResource SectionTitle}" Text="AVAILABLE FAMILIES" VerticalAlignment="Center"/>
                                <TextBlock x:Name="DeviceCountText" Text="0" DockPanel.Dock="Right" Foreground="{StaticResource MutedBrush}" FontSize="12" VerticalAlignment="Center"/>
                            </DockPanel>
                            <UniformGrid Columns="2" Margin="0,4,0,0">
                                <TextBlock Text="ESP32" Foreground="{StaticResource AccentBrush}" Margin="0,6,8,0" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="ESP8266" Foreground="{StaticResource MutedBrush}" Margin="0,6,0,0" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="Arduino" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" Margin="0,8,8,0" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="RP2040" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,0" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="STM32" Foreground="{StaticResource MutedBrush}" Margin="0,8,8,0" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="Teensy / nRF52" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,0" TextTrimming="CharacterEllipsis"/>
                            </UniformGrid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Grid Grid.Column="2" Background="{StaticResource ShellBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="64"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="200"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#12161D" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1">
                <DockPanel Margin="20,0" LastChildFill="False">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Starter Kit" Foreground="{StaticResource MutedBrush}" FontSize="12"/>
                        <TextBlock x:Name="ActiveFileText" Text="src/main.cpp" Foreground="{StaticResource TextBrush}" FontWeight="Bold" TextTrimming="CharacterEllipsis" MaxWidth="480"/>
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Style="{StaticResource ToolButton}" Content="Verify" Margin="0,0,8,0" Click="VerifyClicked"/>
                        <Button Style="{StaticResource PrimaryButton}" Content="Upload" Margin="0,0,8,0" Click="UploadClicked"/>
                        <Button Style="{StaticResource ToolButton}" Content="Serial" Margin="0,0,8,0" Click="SerialClicked"/>
                        <Button Style="{StaticResource ToolButton}" Content="Settings" Click="SettingsClicked"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="360"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="46"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Background="#11151C" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="12,0,0,0">
                            <Button Content="main.cpp" Background="{StaticResource EditorBrush}" BorderBrush="{StaticResource LineBrush}" Height="36" MinWidth="108" Padding="16,0" Click="OpenMainFile"/>
                            <Button Content="platformio.ini" Foreground="{StaticResource MutedBrush}" Height="36" MinWidth="126" Padding="16,0" Click="OpenConfigFile"/>
                            <Button Content="notes" Foreground="{StaticResource MutedBrush}" Height="36" MinWidth="72" Padding="14,0" Click="OpenNotesFile"/>
                        </StackPanel>
                    </Border>
                    <Grid Grid.Row="1" Background="{StaticResource EditorBrush}" ClipToBounds="True">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="56"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="LineNumbersText" Background="#10151D" Foreground="#657184" FontFamily="Consolas" FontSize="14" LineHeight="23" TextAlignment="Right" Padding="0,18,12,0"/>
                        <TextBox x:Name="EditorText" Grid.Column="1" Background="{StaticResource EditorBrush}" Foreground="{StaticResource TextBrush}" BorderThickness="0" FontFamily="Consolas" FontSize="14" Padding="20,16" AcceptsReturn="True" AcceptsTab="True" TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                    </Grid>
                </Grid>

                <Border Grid.Column="1" Background="#131720" BorderBrush="{StaticResource LineBrush}" BorderThickness="1,0,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="16">
                            <Border Style="{StaticResource CardBorder}">
                                <StackPanel>
                                    <DockPanel>
                                        <TextBlock Text="Selected Device" Style="{StaticResource MutedText}"/>
                                        <TextBlock x:Name="DeviceFamilyText" Text="Arduino AVR" DockPanel.Dock="Right" Foreground="{StaticResource TextBrush}" FontWeight="Bold" TextTrimming="CharacterEllipsis" MaxWidth="160"/>
                                    </DockPanel>
                                    <TextBlock x:Name="DeviceDescriptionText" Text="Arduino Uno R3 using the atmelavr platform." TextWrapping="Wrap" Foreground="#C5CEDA" LineHeight="21" Margin="0,12,0,14"/>
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="96"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Platform" Style="{StaticResource MutedText}"/>
                                        <TextBlock x:Name="PlatformText" Grid.Column="1" Text="atmelavr" Style="{StaticResource ValueText}"/>
                                    </Grid>
                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="96"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Board ID" Style="{StaticResource MutedText}"/>
                                        <TextBlock x:Name="BoardIdText" Grid.Column="1" Text="uno" Style="{StaticResource ValueText}"/>
                                    </Grid>
                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="96"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Framework" Style="{StaticResource MutedText}"/>
                                        <TextBlock x:Name="BoardFrameworkText" Grid.Column="1" Text="arduino" Style="{StaticResource ValueText}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardBorder}" Margin="0,14,0,0">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,10">
                                        <TextBlock Text="Project Health" Style="{StaticResource MutedText}"/>
                                        <TextBlock Text="Ready" DockPanel.Dock="Right" Foreground="{StaticResource AccentBrush}" FontWeight="Bold"/>
                                    </DockPanel>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="72"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Project" Style="{StaticResource MutedText}"/>
                                        <TextBlock x:Name="ProjectPathText" Grid.Column="1" Text="StarterKit" Style="{StaticResource ValueText}"/>
                                    </Grid>
                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="72"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Port" Style="{StaticResource MutedText}"/>
                                        <TextBlock Text="Auto" Grid.Column="1" Style="{StaticResource ValueText}"/>
                                    </Grid>
                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="72"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Baud" Style="{StaticResource MutedText}"/>
                                        <TextBlock Text="115200" Grid.Column="1" Style="{StaticResource ValueText}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <Border Grid.Row="2" Background="{StaticResource ConsoleBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="42"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border BorderBrush="{StaticResource SoftLineBrush}" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" Margin="14,6,0,0">
                            <Button Style="{StaticResource DockButton}" Content="Problems" Background="{StaticResource PanelAltBrush}" BorderBrush="{StaticResource LineBrush}" Foreground="{StaticResource TextBrush}" Click="ProblemsClicked"/>
                            <Button Style="{StaticResource DockButton}" Content="Output" Click="OutputClicked"/>
                            <Button Style="{StaticResource DockButton}" Content="Serial Monitor" Click="SerialClicked"/>
                        </StackPanel>
                    </Border>
                    <TextBox x:Name="ConsoleText" Grid.Row="1" Background="{StaticResource ConsoleBrush}" Foreground="{StaticResource MutedBrush}" BorderThickness="0" FontFamily="Consolas" FontSize="13" Padding="18,12" IsReadOnly="True" Text="Ready. PlatformIO commands will run against the StarterKit project." VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
